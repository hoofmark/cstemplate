{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "../../src/HoofMark.CSharpTemplating.Abstractions/HoofMark.CSharpTemplating.Abstractions.csproj",
            "../../src/HoofMark.CSharpTemplating.Core/HoofMark.CSharpTemplating.Core.csproj"
          ]
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "EnumSortOrder": "alphabetic",
      "allowCompilationErrors": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "index.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "output": "../publish/ref",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "cstemplate",
      "_appTitle": "cstemplate",
      "_appFooter": "cstemplate — © HoofMark. Released under the MIT licence.",
      "_enableSearch": true,
      "_appLogoPath": "images/hoofmark_small.png",
      "_appFaviconPath": "images/hoofmark_small.png"
    }
  }
}
