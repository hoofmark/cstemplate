{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "**/HoofMark.CSharpTemplating.Abstractions/HoofMark.CSharpTemplating.Abstractions.csproj",
            "**/HoofMark.CSharpTemplating.Core/HoofMark.CSharpTemplating.Core.csproj"
          ],
          "src": "../../src"
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "EnumSortOrder": "alphabetic",
      "allowCompilationErrors": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "home.md" ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**", "index.html"]
      }
    ],
    "output": "../_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "cstemplate",
      "_appTitle": "cstemplate",
      "_appFooter": "cstemplate — © HoofMark. Released under the MIT licence.",
      "_enableSearch": true,
      "_appLogoPath": "images/hoofmark_mini.jpg",
      "_appFaviconPath": "images/hoofmark_mini.jpg"
    }
  }
}
